    {
      "parameters": {
        "jsCode": "// ─── Guard: validate required fields before hitting the AI ───────────────\nconst item = $input.first().json;\n\nconst missing = [];\nif (!item.full_name)     missing.push('full_name');\nif (!item.email)         missing.push('email');\nif (!item.business_name) missing.push('business_name');\n\n// Basic email format check\nconst emailRe = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (item.email && !emailRe.test(item.email)) {\n  missing.push('email_format');\n}\n\nreturn [{\n  json: {\n    ...item,\n    _validation_passed: missing.length === 0,\n    _validation_errors: missing\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 200],
