    {
      "parameters": {
        "jsCode": "// ─── Parse AI JSON output safely ────────────────────────────────────────\nconst raw = $input.first().json.output ?? '';\n\nlet parsed;\ntry {\n  // Strip accidental markdown fences if model adds them\n  const cleaned = raw.replace(/```json|```/gi, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  // Parsing failed — flag for the error branch\n  return [{\n    json: {\n      ...$input.first().json,\n      _ai_parse_error: true,\n      _ai_raw: raw\n    }\n  }];\n}\n\n// Enforce expected types / defaults\nconst is_qualified  = Boolean(parsed.is_qualified);\nconst score         = Math.min(100, Math.max(0, Number(parsed.score) || 0));\nconst priority      = ['hot','warm','cold'].includes(parsed.priority) ? parsed.priority : (score >= 80 ? 'hot' : score >= 50 ? 'warm' : 'cold');\nconst reasoning     = String(parsed.reasoning || '');\nconst personalized_message = String(parsed.personalized_message || '');\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    _ai_parse_error: false,\n    is_qualified,\n    score,\n    priority,\n    reasoning,\n    personalized_message\n  }\n}];\n"
      },
